{
  "version": 2,
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/calculator", "dest": "/calculator.php" },
    { "src": "/map", "dest": "/map.php" },
    { "src": "/dashboard", "dest": "/dashboard.php" },
    { "src": "/admin", "dest": "/admin.php" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}